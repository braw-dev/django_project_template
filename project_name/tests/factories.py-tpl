from datetime import timedelta

import factory
from django.contrib.auth import get_user_model
from django.utils import timezone
from {{ project_name }}.billing import models as billing_models
from {{ project_name }}.tenancy import models as tenancy_models

User = get_user_model()


class UserFactory(factory.django.DjangoModelFactory):
    class Meta:
        model = User

    email = factory.Sequence(lambda n: f"user{n}@example.com")
    password = factory.PostGenerationMethodCall("set_password", "testpass123")
    is_active = True


class TeamFactory(factory.django.DjangoModelFactory):
    class Meta:
        model = tenancy_models.Team

    name = factory.Sequence(lambda n: f"Team {n}")
    slug = factory.Sequence(lambda n: f"team-{n}")


class TeamMembershipFactory(factory.django.DjangoModelFactory):
    class Meta:
        model = tenancy_models.TeamMembership

    team = factory.SubFactory(TeamFactory)
    user = factory.SubFactory(UserFactory)
    role = tenancy_models.TeamRole.MEMBER


class SubscriptionFactory(factory.django.DjangoModelFactory):
    class Meta:
        model = billing_models.Subscription

    team = factory.SubFactory(TeamFactory)
    provider = billing_models.BillingProviderChoices.POLAR
    external_subscription_id = factory.Sequence(lambda n: f"sub_{n}")
    external_customer_id = factory.Sequence(lambda n: f"cust_{n}")
    external_product_id = factory.Sequence(lambda n: f"prod_{n}")
    status = billing_models.SubscriptionStatus.ACTIVE
    current_period_end = factory.LazyFunction(lambda: timezone.now() + timedelta(days=30))
