import json
from datetime import timedelta
from io import StringIO

from allauth.account.models import EmailAddress
from allauth.mfa.models import Authenticator
from django.conf import settings
from django.contrib import admin
from django.contrib.auth import get_user_model
from django.core.management import CommandError, call_command
from django.test import RequestFactory, TestCase
from django.urls import reverse
from django.utils import timezone

from {{ project_name }}.core.models import AuditEvent, NewsletterSignup
from {{ project_name }}.tenancy import services as tenancy_services
from {{ project_name }}.tenancy.models import TeamInvitation, TeamMembership, TeamRole
from {{ project_name }}.tokens.models import ApiToken, hash_token_secret

from .admin import UserAdmin
from .privacy import PrivacyOperationError, delete_user_data, export_user_data

User = get_user_model()


class UserModelTest(TestCase):
    def test_user_model_uses_email_as_username(self):
        self.assertEqual(User.USERNAME_FIELD, "email")


class PasskeySignupTest(TestCase):
    def test_signup_page_shows_passkey_signup_option(self):
        response = self.client.get(reverse("account_signup"))

        self.assertContains(response, reverse("account_signup_by_passkey"))

    def test_passkey_signup_page_uses_template(self):
        response = self.client.get(reverse("account_signup_by_passkey"))

        self.assertTemplateUsed(response, "account/signup_by_passkey.html")


class PrivacyOperationsTest(TestCase):
    def setUp(self):
        self.request_factory = RequestFactory()
        self.admin_user = User.objects.create_superuser(
            email="admin@example.com",
            password="password",
        )
        self.owner = User.objects.create_user(email="owner@example.com", password="password")
        self.member = User.objects.create_user(email="member@example.com", password="password")
        self.team = tenancy_services.create_team(name="Acme", slug="acme", owner=self.owner)
        TeamMembership.objects.create(team=self.team, user=self.member, role=TeamRole.MEMBER)
        TeamInvitation.objects.create(
            team=self.team,
            email=self.member.email,
            invited_by=self.owner,
            expires_at=timezone.now() + timedelta(days=7),
        )
        NewsletterSignup.objects.create(
            email=self.member.email,
            consented_at=timezone.now(),
            confirmed_at=timezone.now(),
        )
        EmailAddress.objects.create(
            user=self.member,
            email=self.member.email,
            primary=True,
            verified=True,
        )
        Authenticator.objects.create(
            user=self.member,
            type=Authenticator.Type.TOTP,
            data={"secret": "totp-secret"},
        )
        self.created_token = ApiToken.objects.create(
            team=self.team,
            name="CLI token",
            lookup_id="membertokenlook",
            secret_hash=hash_token_secret("secret-one"),
            display_prefix="mst_",
            created_by=self.member,
        )
        self.revoked_token = ApiToken.objects.create(
            team=self.team,
            name="Revoked token",
            lookup_id="ownertokenlook1",
            secret_hash=hash_token_secret("secret-two"),
            display_prefix="mst_",
            created_by=self.owner,
            revoked_by=self.member,
            revoked_at=timezone.now(),
        )

    def test_export_user_data_returns_basic_user_bundle(self):
        payload = export_user_data(
            user=self.member,
            actor=self.admin_user,
            metadata={"origin": "test"},
        )

        self.assertEqual(payload["schema_version"], 1)
        self.assertEqual(payload["user"]["email"], self.member.email)
        self.assertEqual(payload["email_addresses"][0]["email"], self.member.email)
        self.assertEqual(payload["mfa_authenticators"][0]["type"], Authenticator.Type.TOTP)
        self.assertEqual(payload["newsletter_signups"][0]["email"], self.member.email)
        self.assertEqual(payload["team_memberships"][0]["team_slug"], self.team.slug)
        self.assertEqual(payload["team_invitations"][0]["team_slug"], self.team.slug)
        self.assertEqual(payload["api_tokens_created"][0]["token_id"], self.created_token.token_id)

        audit_event = AuditEvent.objects.get(event_type="privacy.user_data_exported")
        self.assertEqual(audit_event.actor, self.admin_user)
        self.assertEqual(audit_event.subject_user, self.member)
        self.assertEqual(audit_event.subject_email, self.member.email)
        self.assertEqual(audit_event.metadata["origin"], "test")

    def test_delete_user_data_deletes_user_and_directly_linked_records(self):
        result = delete_user_data(
            user=self.member,
            actor=self.admin_user,
            metadata={"origin": "test"},
        )

        self.assertEqual(result["newsletter_signups_deleted"], 1)
        self.assertEqual(result["api_tokens_created_deleted"], 1)
        self.assertEqual(result["api_tokens_revoked_by_cleared"], 1)
        self.assertFalse(User.objects.filter(pk=self.member.pk).exists())
        self.assertFalse(NewsletterSignup.objects.filter(email=self.member.email).exists())
        self.assertFalse(ApiToken.all_objects.filter(pk=self.created_token.pk).exists())
        self.assertFalse(TeamMembership.objects.filter(user_id=self.member.pk).exists())

        self.revoked_token.refresh_from_db()
        self.assertIsNone(self.revoked_token.revoked_by)

        audit_event = AuditEvent.objects.get(event_type="privacy.user_data_deleted")
        self.assertEqual(audit_event.actor, self.admin_user)
        self.assertIsNone(audit_event.subject_user)
        self.assertEqual(audit_event.subject_email, self.member.email)
        self.assertEqual(audit_event.metadata["origin"], "test")

    def test_delete_user_data_rejects_team_owner(self):
        with self.assertRaisesMessage(PrivacyOperationError, "still own teams"):
            delete_user_data(
                user=self.owner,
                actor=self.admin_user,
                metadata={"origin": "test"},
            )

        audit_event = AuditEvent.objects.get(event_type="privacy.user_data_delete_blocked")
        self.assertEqual(audit_event.actor, self.admin_user)
        self.assertEqual(audit_event.subject_user, self.owner)
        self.assertEqual(audit_event.metadata["reason"], "user_still_owns_teams")

    def test_export_user_data_command_writes_json_to_stdout(self):
        stdout = StringIO()

        call_command("export_user_data", self.member.email, stdout=stdout)

        payload = json.loads(stdout.getvalue())
        self.assertEqual(payload["user"]["email"], self.member.email)

        audit_event = AuditEvent.objects.get(event_type="privacy.user_data_exported")
        self.assertEqual(audit_event.metadata["origin"], "management_command")
        self.assertEqual(audit_event.metadata["command"], "export_user_data")

    def test_delete_user_data_command_requires_confirmation(self):
        with self.assertRaisesMessage(CommandError, "without --yes"):
            call_command("delete_user_data", self.member.email)

    def test_delete_user_data_command_deletes_user(self):
        stdout = StringIO()

        call_command("delete_user_data", self.member.email, "--yes", stdout=stdout)

        self.assertFalse(User.objects.filter(pk=self.member.pk).exists())
        self.assertIn("Deleted user data for member@example.com.", stdout.getvalue())

        audit_event = AuditEvent.objects.get(event_type="privacy.user_data_deleted")
        self.assertEqual(audit_event.metadata["origin"], "management_command")
        self.assertEqual(audit_event.metadata["command"], "delete_user_data")

    def test_user_admin_registers_privacy_actions(self):
        request = self.request_factory.get("/admin/users/user/")
        request.user = self.admin_user
        user_admin = UserAdmin(User, admin.site)

        actions = user_admin.get_actions(request)

        self.assertIn("export_selected_users_data", actions)
        self.assertIn("delete_selected_users_data", actions)

    def test_user_admin_export_action_returns_json_attachment(self):
        request = self.request_factory.post("/admin/users/user/")
        request.user = self.admin_user
        user_admin = UserAdmin(User, admin.site)

        response = user_admin.export_selected_users_data(
            request,
            User.objects.filter(pk=self.member.pk),
        )

        self.assertEqual(response.status_code, 200)
        self.assertEqual(response["Content-Type"], "application/json")
        expected_filename = (
            f"{timezone.now().strftime('%Y%m%d')}-{settings.PROJECT_SLUG}"
            "-user-data-member-example.com.json"
        )
        self.assertIn(
            f'attachment; filename="{expected_filename}"',
            response["Content-Disposition"],
        )

        audit_event = AuditEvent.objects.get(event_type="privacy.user_data_exported")
        self.assertEqual(audit_event.actor, self.admin_user)
        self.assertEqual(audit_event.subject_user, self.member)
        self.assertEqual(audit_event.metadata["origin"], "django_admin")


class MFARequiredDecoratorTest(TestCase):
    email = "jane@example.com"
    password = "iKDt6EFwyQEjkgqSzCdvFdC7imS5JN0H"

    def setUp(self):
        self.user = User.objects.create_user(email=self.email, password=self.password)
        EmailAddress.objects.create(
            user=self.user,
            email=self.email,
            primary=True,
            verified=True,
        )
        self.team = tenancy_services.create_team(name="Acme", slug="acme", owner=self.user)

    def test_verified_user_without_mfa_is_redirected_to_mfa_setup(self):
        self.client.force_login(self.user)

        response = self.client.get(reverse("account:dashboard"))

        self.assertRedirects(response, reverse("mfa_index"))

    def test_verified_user_can_access_dashboard_with_totp_enabled(self):
        Authenticator.objects.create(
            user=self.user,
            type=Authenticator.Type.TOTP,
            data={"secret": "totp-secret"},
        )
        self.client.force_login(self.user)

        response = self.client.get(reverse("account:dashboard"))

        self.assertTemplateUsed(response, "core/pages/dashboard.html")

    def test_verified_user_can_access_dashboard_with_passkey_enabled(self):
        Authenticator.objects.create(
            user=self.user,
            type=Authenticator.Type.WEBAUTHN,
            data={"credential_id": "passkey-id"},
        )
        self.client.force_login(self.user)

        response = self.client.get(reverse("account:dashboard"))

        self.assertTemplateUsed(response, "core/pages/dashboard.html")

    def test_verified_user_without_mfa_is_redirected_to_mfa_setup_for_team_dashboard(self):
        self.client.force_login(self.user)

        response = self.client.get(reverse("team_dashboard", kwargs={"team_slug": self.team.slug}))

        self.assertRedirects(response, reverse("mfa_index"))
