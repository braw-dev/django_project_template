import uuid
from unittest.mock import MagicMock, patch

from django.contrib.auth import get_user_model
from django.test import TestCase
from django.urls import reverse

from . import selectors
from .billing.formatting import format_currency_amount

User = get_user_model()


###############################################
## Test cases
###############################################
class AuthTestCase(TestCase):
    password = "iKDt6EFwyQEjkgqSzCdvFdC7imS5JN0H"

    def setUp(self):
        self.email = f"{uuid.uuid4()}@example.com"

    def test_register_view_uses_template(self):
        response = self.client.get(reverse("account_signup"))

        self.assertTemplateUsed(response, "account/signup.html")

    def test_register_successfully_registers_user(self):
        form_data = {
            "email": self.email,
            "password1": self.password,
            "password2": self.password,
        }

        self.client.post(
            reverse("account_signup"),
            data=form_data,
        )

        users = User.objects.filter(email=self.email)
        self.assertEqual(users.count(), 1)

    def test_register_redirects_to_email_verification_on_valid_data(self):
        form_data = {
            "email": self.email,
            "password1": self.password,
            "password2": self.password,
        }

        response = self.client.post(
            reverse("account_signup"),
            data=form_data,
        )

        self.assertRedirects(response, reverse("account_email_verification_sent"))

    @patch("{{ project_name }}.core.signals.track_plausible_event")
    def test_register_tracks_signup_conversion(self, mock_track_plausible_event):
        response = self.client.post(
            reverse("account_signup"),
            data={
                "email": self.email,
                "password1": self.password,
                "password2": self.password,
            },
        )

        self.assertRedirects(response, reverse("account_email_verification_sent"))
        mock_track_plausible_event.assert_called_once()
        self.assertEqual(mock_track_plausible_event.call_args.kwargs["event_name"], "Signup")

    def test_register_shows_error_on_invalid_password(self):
        form_data = {"email": self.email, "password1": "", "password2": ""}

        response = self.client.post(
            reverse("account_signup"),
            data=form_data,
        )

        self.assertTemplateUsed(response, "account/signup.html")
        self.assertContains(response, "This field is required")

    def test_register_shows_error_on_invalid_email(self):
        form_data = {
            "email": "not-an-email",
            "password1": self.password,
            "password2": self.password,
        }

        response = self.client.post(
            reverse("account_signup"),
            data=form_data,
        )

        self.assertTemplateUsed(response, "account/signup.html")
        self.assertContains(response, "Enter a valid email address")

    def test_dashboard_view_requires_login(self):
        response = self.client.get(reverse("account:dashboard"))

        self.assertRedirects(
            response,
            f"{reverse('account_login')}?next={reverse('account:dashboard')}",
        )


class PricingHelperTestCase(TestCase):
    def test_format_currency_amount_supports_supported_currencies(self):
        self.assertEqual(
            format_currency_amount(amount_minor=1900, currency="EUR", locale="de"),
            "19,00\xa0€",
        )
        self.assertEqual(
            format_currency_amount(amount_minor=1900, currency="CHF", locale="de"),
            "19,00\xa0CHF",
        )
        self.assertEqual(
            format_currency_amount(amount_minor=1900, currency="GBP", locale="en"),
            "£19.00",
        )
        self.assertEqual(
            format_currency_amount(amount_minor=1900, currency="USD", locale="en"),
            "$19.00",
        )

    def test_product_list_maps_provider_products_for_pricing_page(self):
        billing_provider = MagicMock()
        billing_provider.get_products.return_value = [
            {
                "id": "prod_starter",
                "name": "Starter",
                "description": "For smaller teams",
                "is_recurring": True,
                "recurring_interval": "month",
                "recurring_interval_count": 1,
                "prices": [
                    {
                        "amount_type": "fixed",
                        "price_amount": 1900,
                        "price_currency": "eur",
                        "is_archived": False,
                    }
                ],
                "benefits": [
                    {"id": "analytics", "name": "Analytics"},
                    {"id": "support", "name": "Priority support"},
                ],
            }
        ]

        with patch(
            "{{ project_name }}.billing.services.get_billing_provider",
            return_value=billing_provider,
        ):
            products = selectors.product_list(locale="de")

        self.assertEqual(len(products), 1)
        self.assertEqual(products[0]["name"], "Starter")
        self.assertEqual(products[0]["description"], "For smaller teams")
        self.assertEqual(products[0]["price_display"], "19,00\xa0€")
        self.assertEqual(products[0]["price_currency"], "EUR")
        self.assertEqual(str(products[0]["billing_interval_display"]), "month")
        self.assertEqual(products[0]["features"], ["Analytics", "Priority support"])

    def test_pricing_page_renders_provider_backed_products(self):
        products = [
            {
                "id": "prod_starter",
                "name": "Starter",
                "description": "For smaller teams",
                "price_display": "19,00\xa0€",
                "price_currency": "EUR",
                "price_label": "",
                "has_numeric_price": True,
                "billing_interval_display": "month",
                "features": ["Analytics"],
            }
        ]

        with patch("{{ project_name }}.views.selectors.product_list", return_value=products):
            response = self.client.get(reverse("pricing"))

        self.assertContains(response, "Starter")
        self.assertContains(response, "For smaller teams")
        self.assertContains(response, "19,00")
        self.assertContains(response, "€")
        self.assertContains(response, "Analytics")
        self.assertContains(
            response,
            "Prices shown exclude VAT. Final tax is calculated at checkout.",
        )
        self.assertContains(
            response,
            "Invoices and tax documents are handled by the billing provider",
        )
        self.assertContains(response, "during checkout and after payment.")

    def test_pricing_page_renders_empty_state_without_products(self):
        with patch("{{ project_name }}.views.selectors.product_list", return_value=[]):
            response = self.client.get(reverse("pricing"))

        self.assertContains(response, "Pricing details coming soon")
        self.assertContains(response, "No public plans are configured yet.")
        self.assertContains(
            response,
            "Prices shown exclude VAT. Final tax is calculated at checkout.",
        )
