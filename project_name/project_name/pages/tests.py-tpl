from django.template import Context, Template
from django.test import TestCase, override_settings
from django.urls import reverse

from .models import Page


class SeededTrustPagesTestCase(TestCase):
    def test_seeded_trust_pages_are_published_and_render(self):
        expected_pages = {
            "privacy": "Privacy",
            "terms": "Terms",
            "cookies": "Cookies",
            "security": "Security",
            "subprocessors": "Subprocessors",
            "contact": "Contact",
            "faq-account-access": "How do I regain access to my account?",
            "faq-billing": "How does billing and cancellation work?",
            "faq-security": "How is customer data protected?",
            "faq-security-hosting": (
                "Where is the application hosted and where is customer data stored?"
            ),
            "faq-security-encryption": "Is customer data encrypted in transit and at rest?",
            "faq-security-backups": "How do backups and disaster recovery work?",
            "faq-security-mfa": "Do you support MFA and account protection controls?",
            "faq-security-support-access": "Can support staff access customer accounts or data?",
            "faq-performance-uptime": "What uptime and performance should customers expect?",
        }

        for slug, title in expected_pages.items():
            with self.subTest(slug=slug):
                page = Page.objects.get(slug=slug)
                self.assertTrue(page.is_published)
                response = self.client.get(reverse("pages:page_detail", kwargs={"slug": slug}))
                self.assertEqual(response.status_code, 200)
                self.assertContains(response, title)
                self.assertContains(response, "REPLACE_ME")

    def test_subprocessors_page_includes_hosting_inventory_starter_sections(self):
        response = self.client.get(reverse("pages:page_detail", kwargs={"slug": "subprocessors"}))

        self.assertContains(response, "Subprocessors")
        self.assertContains(response, "Hosting inventory")
        self.assertContains(response, "Customer data involved")
        self.assertContains(response, "Application hosting")

    def test_cookies_page_renders_cookie_preferences_component(self):
        response = self.client.get(reverse("pages:page_detail", kwargs={"slug": "cookies"}))

        self.assertContains(response, "Cookie preferences")
        self.assertContains(response, "Allow optional tools")
        self.assertContains(response, "Use only required cookies")

    def test_homepage_footer_links_to_seeded_trust_pages(self):
        response = self.client.get("/")

        self.assertContains(response, reverse("pages:page_detail", kwargs={"slug": "privacy"}))
        self.assertContains(response, reverse("pages:page_detail", kwargs={"slug": "cookies"}))
        self.assertContains(response, reverse("pages:page_detail", kwargs={"slug": "terms"}))
        self.assertContains(response, reverse("pages:page_detail", kwargs={"slug": "security"}))
        self.assertContains(
            response,
            reverse("pages:page_detail", kwargs={"slug": "subprocessors"}),
        )

    def test_homepage_footer_links_to_support_pages(self):
        response = self.client.get("/")

        self.assertContains(response, reverse("pages:support_index"))
        self.assertContains(response, reverse("pages:page_detail", kwargs={"slug": "contact"}))


class SupportIndexTestCase(TestCase):
    def test_support_index_lists_categorized_faqs_and_contact_link(self):
        response = self.client.get(reverse("pages:support_index"))

        self.assertEqual(response.status_code, 200)
        self.assertContains(response, "Support")
        self.assertContains(response, "Account and access")
        self.assertContains(response, "Billing")
        self.assertContains(response, "Security")
        self.assertContains(response, "Performance and reliability")
        self.assertContains(response, "How do I regain access to my account?")
        self.assertContains(response, "How does billing and cancellation work?")
        self.assertContains(response, "Can support staff access customer accounts or data?")
        self.assertContains(response, "What uptime and performance should customers expect?")
        self.assertContains(response, reverse("pages:page_detail", kwargs={"slug": "contact"}))

    def test_support_index_filters_faqs_by_search_query(self):
        response = self.client.get(reverse("pages:support_index"), {"q": "billing"})

        self.assertContains(response, "Billing")
        self.assertContains(response, "How does billing and cancellation work?")
        self.assertNotContains(response, "How do I regain access to my account?")
        self.assertNotContains(response, "Can support staff access customer accounts or data?")


class HomepageFeaturedFaqTestCase(TestCase):
    def test_homepage_shows_featured_faqs_and_support_link(self):
        response = self.client.get("/")

        self.assertEqual(response.status_code, 200)
        self.assertContains(response, "Featured questions")
        self.assertContains(response, "How is customer data protected?")
        self.assertContains(response, "Can support staff access customer accounts or data?")
        self.assertContains(response, "What uptime and performance should customers expect?")
        self.assertContains(response, reverse("pages:support_index"))


class SitemapAndRobotsTestCase(TestCase):
    @override_settings(DEBUG=False, IS_PRODUCTION=True)
    def test_sitemap_xml_is_available_in_production(self):
        response = self.client.get(reverse("sitemap"))

        self.assertEqual(response.status_code, 200)
        self.assertEqual(response["Content-Type"], "application/xml")
        self.assertContains(response, "/privacy/")

    @override_settings(DEBUG=False, IS_PRODUCTION=True)
    def test_robots_txt_allows_indexing_in_production(self):
        response = self.client.get(reverse("robots_txt"))

        self.assertEqual(response.status_code, 200)
        self.assertEqual(response["Content-Type"], "text/plain")
        self.assertContains(response, "User-agent: *")
        self.assertContains(response, "Allow: /")
        self.assertContains(response, "Sitemap: http://testserver/sitemap.xml")

    @override_settings(DEBUG=True, IS_PRODUCTION=False)
    def test_robots_txt_disallows_indexing_outside_production(self):
        response = self.client.get(reverse("robots_txt"))

        self.assertEqual(response.status_code, 200)
        self.assertEqual(response["Content-Type"], "text/plain")
        self.assertContains(response, "User-agent: *")
        self.assertContains(response, "Disallow: /")


class PageMarkdownSanitizationTestCase(TestCase):
    def test_page_detail_sanitizes_rendered_markdown(self):
        Page.objects.create(
            slug="about",
            is_published=True,
            title="About",
            content=(
                "# Hello\n\n"
                "<script>alert('xss')</script>\n\n"
                "[Safe link](https://example.com)\n\n"
                "[Bad link](javascript:alert('xss'))"
            ),
        )

        response = self.client.get(reverse("pages:page_detail", kwargs={"slug": "about"}))
        content = response.content.decode()

        self.assertContains(response, "<h1")
        self.assertIn('href="https://example.com"', content)
        self.assertNotIn("alert('xss')", content)
        self.assertNotIn("javascript:alert", content)

    def test_markdown_template_filter_sanitizes_rendered_html(self):
        rendered = Template("{" + "% load markdown_tags %}" + "{" + "{ content|markdown }}").render(
            Context(
                {
                    "content": (
                        "<script>alert('xss')</script>\n\n"
                        "[Safe link](https://example.com)\n\n"
                        "[Bad link](javascript:alert('xss'))"
                    )
                }
            )
        )

        self.assertIn('href="https://example.com"', rendered)
        self.assertNotIn("<script", rendered)
        self.assertNotIn("javascript:alert", rendered)
