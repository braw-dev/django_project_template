class NewsletterTestCase(TestCase):
    def setUp(self):
        self.email = f"{uuid.uuid4()}@example.com"

    def test_newsletter_signup_uses_correct_template(self):
        response = self.client.get(reverse("newsletter:signup"))
        self.assertEqual(response.status_code, 200)
        self.assertTemplateUsed(response, "core/pages/newsletter/signup.html")

    def test_newsletter_signup_uses_form(self):
        response = self.client.get(reverse("newsletter:signup"))
        self.assertIsInstance(response.context["form"], NewsletterSignupForm)

    def test_newsletter_signup_redirects_on_success(self):
        response = self.client.post(
            reverse("newsletter:signup"),
            {"email": self.email, "consent": "on"},
        )
        self.assertRedirects(response, reverse("newsletter:signup_success"))

    def test_newsletter_signup_creates_pending_signup_and_sends_confirmation_email(self):
        self.client.post(reverse("newsletter:signup"), {"email": self.email, "consent": "on"})

        signup = core_models.NewsletterSignup.objects.get(email=self.email)
        self.assertIsNotNone(signup.consented_at)
        self.assertIsNone(signup.confirmed_at)
        self.assertEqual(len(mail.outbox), 1)
        self.assertEqual(mail.outbox[0].to, [self.email])
        self.assertIn("Confirm your newsletter subscription", mail.outbox[0].subject)

    def test_legal_updates_signup_creates_pending_signup_with_legal_updates_purpose(self):
        response = self.client.post(
            reverse("newsletter:legal_updates_signup"),
            {"email": self.email, "consent": "on"},
        )

        signup = core_models.NewsletterSignup.objects.get(
            email=self.email,
            purpose=core_models.NewsletterSignupPurpose.LEGAL_UPDATES,
        )
        self.assertRedirects(response, reverse("newsletter:legal_updates_success"))
        self.assertIsNotNone(signup.consented_at)
        self.assertEqual(len(mail.outbox), 1)
        self.assertIn("Confirm your legal updates subscription", mail.outbox[0].subject)

    def test_newsletter_signup_requires_consent(self):
        response = self.client.post(reverse("newsletter:signup"), {"email": self.email})
        self.assertContains(response, escape(NewsletterSignupForm.CONSENT_REQUIRED_ERROR))
        self.assertFalse(core_models.NewsletterSignup.objects.filter(email=self.email).exists())

    def test_newsletter_signup_does_not_create_duplicate_active_signup(self):
        signup = core_models.NewsletterSignup.objects.create(
            email=self.email,
            consented_at=timezone.now(),
            confirmed_at=timezone.now(),
        )
        self.client.post(reverse("newsletter:signup"), {"email": signup.email, "consent": "on"})
        self.assertEqual(core_models.NewsletterSignup.objects.filter(email=signup.email).count(), 1)

    def test_newsletter_signup_shows_info_message_on_duplicate_active_email(self):
        core_models.NewsletterSignup.objects.create(
            email=self.email,
            consented_at=timezone.now(),
            confirmed_at=timezone.now(),
        )
        response = self.client.post(
            reverse("newsletter:signup"),
            {"email": self.email, "consent": "on"},
        )
        self.assertContains(response, escape(NewsletterSignupForm.ALREADY_SUBSCRIBED_ERROR))

    def test_newsletter_signup_resends_confirmation_for_unconfirmed_signup_after_cooldown(self):
        core_models.NewsletterSignup.objects.create(
            email=self.email,
            confirmation_email_sent_at=timezone.now() - timedelta(minutes=16),
        )

        self.client.post(reverse("newsletter:signup"), {"email": self.email, "consent": "on"})

        signup = core_models.NewsletterSignup.objects.get(email=self.email)
        self.assertIsNotNone(signup.consented_at)
        self.assertIsNone(signup.confirmed_at)
        self.assertEqual(len(mail.outbox), 1)
        self.assertIsNotNone(signup.confirmation_email_sent_at)

    def test_newsletter_signup_does_not_resend_confirmation_within_cooldown(self):
        sent_at = timezone.now()
        core_models.NewsletterSignup.objects.create(
            email=self.email,
            confirmation_email_sent_at=sent_at,
        )

        self.client.post(reverse("newsletter:signup"), {"email": self.email, "consent": "on"})

        signup = core_models.NewsletterSignup.objects.get(email=self.email)
        self.assertEqual(len(mail.outbox), 0)
        self.assertEqual(signup.confirmation_email_sent_at, sent_at)

    def test_newsletter_confirmation_marks_signup_confirmed(self):
        signup = core_models.NewsletterSignup.objects.create(
            email=self.email,
            consented_at=timezone.now(),
        )
        token = get_newsletter_confirmation_token(signup)

        response = self.client.get(reverse("newsletter:confirm", kwargs={"token": token}))

        signup.refresh_from_db()
        self.assertEqual(response.status_code, 200)
        self.assertIsNotNone(signup.confirmed_at)
        self.assertContains(response, "Your newsletter subscription has been confirmed.")

    def test_newsletter_confirmation_handles_invalid_token(self):
        response = self.client.get(reverse("newsletter:confirm", kwargs={"token": "invalid"}))

        self.assertEqual(response.status_code, 200)
        self.assertContains(response, "We could not confirm your subscription.")

    def test_newsletter_signup_shows_client_error_on_invalid_email(self):
        response = self.client.post(
            reverse("newsletter:signup"),
            {"email": "invalid-email", "consent": "on"},
        )
        self.assertContains(response, 'aria-invalid="true"')

    def test_newsletter_signup_shown_on_homepage(self):
        response = self.client.get("/")
        self.assertEqual(response.status_code, 200)
        self.assertTemplateUsed(response, "core/partials/newsletter/signup.html")

    @override_settings(ACCOUNT_RATE_LIMITS={"newsletter_signup": "1/m/key"})
    def test_newsletter_signup_returns_429_when_rate_limited(self):
        response = self.client.post(
            reverse("newsletter:signup"),
            {"email": self.email, "consent": "on"},
        )
        self.assertRedirects(response, reverse("newsletter:signup_success"))

        limited_response = self.client.post(
            reverse("newsletter:signup"),
            {"email": self.email, "consent": "on"},
        )

        self.assertEqual(limited_response.status_code, 429)
        self.assertTemplateUsed(limited_response, "429.html")

    @override_settings(ACCOUNT_RATE_LIMITS={"newsletter_signup": "1/m/key"})
    def test_legal_updates_signup_returns_429_when_rate_limited(self):
        response = self.client.post(
            reverse("newsletter:legal_updates_signup"),
            {"email": self.email, "consent": "on"},
        )
        self.assertRedirects(response, reverse("newsletter:legal_updates_success"))

        limited_response = self.client.post(
            reverse("newsletter:legal_updates_signup"),
            {"email": self.email, "consent": "on"},
        )

        self.assertEqual(limited_response.status_code, 429)
        self.assertTemplateUsed(limited_response, "429.html")

    def test_newsletter_model_tracks_purpose(self):
        signup = core_models.NewsletterSignup.objects.create(
            email=self.email,
            purpose=core_models.NewsletterSignupPurpose.MARKETING,
        )

        self.assertEqual(signup.purpose, core_models.NewsletterSignupPurpose.MARKETING)

    def test_newsletter_model_tracks_optional_unsubscribe_fields(self):
        signup = core_models.NewsletterSignup.objects.create(email=self.email)

        self.assertIsNone(signup.confirmation_email_sent_at)
        self.assertIsNone(signup.unsubscribed_at)
        self.assertEqual(signup.unsubscribe_reason, "")


class AuditEventTestCase(TestCase):
    def setUp(self):
        self.request_factory = RequestFactory()
        self.actor = User.objects.create_superuser(email="staff@example.com", password="password")
        self.subject = User.objects.create_user(email="customer@example.com", password="password")
        self.team = tenancy_services.create_team(name="Acme", slug="acme", owner=self.subject)

    def test_audit_event_is_append_only(self):
        audit_event = core_models.AuditEvent.objects.create(event_type="test.event")
        audit_event.event_type = "test.event.changed"

        with self.assertRaisesMessage(RuntimeError, "append-only"):
            audit_event.save()

        with self.assertRaisesMessage(RuntimeError, "append-only"):
            audit_event.delete()

    def test_audit_event_can_be_deleted_only_with_explicit_allow_flag(self):
        audit_event = core_models.AuditEvent.objects.create(event_type="test.event")

        with self.assertRaisesMessage(RuntimeError, "append-only"):
            audit_event.delete()

        audit_event.delete(_allow_delete=True)

        self.assertFalse(core_models.AuditEvent.objects.filter(pk=audit_event.pk).exists())

    def test_audit_event_queryset_delete_requires_explicit_allow_flag(self):
        audit_event = core_models.AuditEvent.objects.create(event_type="test.event")

        with self.assertRaisesMessage(RuntimeError, "append-only"):
            core_models.AuditEvent.objects.filter(pk=audit_event.pk).delete()

        core_models.AuditEvent.objects.filter(pk=audit_event.pk).delete(_allow_delete=True)

        self.assertFalse(core_models.AuditEvent.objects.filter(pk=audit_event.pk).exists())

    @override_settings(AUDIT_EVENT_RETENTION_DAYS=30)
    def test_audit_prune_command_deletes_old_events_and_records_prune_event(self):
        old_event_one = core_models.AuditEvent.objects.create(
            event_type=core_models.AuditEventType.TOKENS_API_TOKEN_CREATED,
            created_at=timezone.now() - timedelta(days=31),
        )
        old_event_two = core_models.AuditEvent.objects.create(
            event_type=core_models.AuditEventType.TOKENS_API_TOKEN_REVOKED,
            created_at=timezone.now() - timedelta(days=32),
        )
        recent_event = core_models.AuditEvent.objects.create(
            event_type=core_models.AuditEventType.USERS_LOGIN_SUCCEEDED,
            created_at=timezone.now() - timedelta(days=5),
        )

        core_models.AuditEvent.objects.filter(pk=old_event_one.pk).update(
            created_at=timezone.now() - timedelta(days=31)
        )
        core_models.AuditEvent.objects.filter(pk=old_event_two.pk).update(
            created_at=timezone.now() - timedelta(days=32)
        )
        core_models.AuditEvent.objects.filter(pk=recent_event.pk).update(
            created_at=timezone.now() - timedelta(days=5)
        )

        call_command("audit_prune", "--batch-size", "1")

        self.assertFalse(core_models.AuditEvent.objects.filter(pk=old_event_one.pk).exists())
        self.assertFalse(core_models.AuditEvent.objects.filter(pk=old_event_two.pk).exists())
        self.assertTrue(core_models.AuditEvent.objects.filter(pk=recent_event.pk).exists())

        prune_events = core_models.AuditEvent.objects.filter(
            event_type=core_models.AuditEventType.AUDIT_RETENTION_PRUNED
        ).order_by("created_at")
        self.assertEqual(prune_events.count(), 2)
        self.assertEqual(prune_events[0].metadata["pruned_count"], 1)
        self.assertEqual(prune_events[1].metadata["pruned_count"], 1)

    @override_settings(AUDIT_EVENT_RETENTION_DAYS=0)
    def test_audit_prune_command_requires_positive_retention_window(self):
        with self.assertRaisesMessage(CommandError, "AUDIT_EVENT_RETENTION_DAYS"):
            call_command("audit_prune")

    def test_audit_event_admin_is_read_only(self):
        request = self.request_factory.get("/admin/core/auditevent/")
        request.user = self.actor
        audit_admin = AuditEventAdmin(core_models.AuditEvent, admin.site)

        self.assertFalse(audit_admin.has_add_permission(request))
        self.assertFalse(audit_admin.has_change_permission(request))
        self.assertFalse(audit_admin.has_delete_permission(request))

    def test_hijack_started_signal_creates_audit_event(self):
        request = self.request_factory.post(
            "/hijack/acquire/",
            REMOTE_ADDR="127.0.0.1",
            HTTP_X_FORWARDED_FOR="203.0.113.10, 127.0.0.1",
            HTTP_USER_AGENT="test-agent",
        )

        hijack_started.send(
            sender=None,
            request=request,
            hijacker=self.actor,
            hijacked=self.subject,
        )

        audit_event = core_models.AuditEvent.objects.get(
            event_type=core_models.AuditEventType.SUPPORT_HIJACK_STARTED
        )
        self.assertEqual(audit_event.actor, self.actor)
        self.assertEqual(audit_event.subject_user, self.subject)
        self.assertEqual(audit_event.subject_email, self.subject.email)
        self.assertEqual(audit_event.ip_address, "127.0.0.1")
        self.assertEqual(audit_event.user_agent, "test-agent")
        self.assertEqual(audit_event.metadata["origin"], "django_hijack")

    @override_settings(IS_PRODUCTION=True, TRUSTED_PROXY_IPS=["127.0.0.1"])
    def test_hijack_ended_signal_uses_forwarded_ip_from_trusted_proxy(self):
        request = self.request_factory.post(
            "/hijack/release/",
            REMOTE_ADDR="127.0.0.1",
            HTTP_X_FORWARDED_FOR="203.0.113.20, 127.0.0.1",
            HTTP_USER_AGENT="test-agent",
        )

        hijack_ended.send(
            sender=None,
            request=request,
            hijacker=self.actor,
            hijacked=self.subject,
        )

        audit_event = core_models.AuditEvent.objects.get(
            event_type=core_models.AuditEventType.SUPPORT_HIJACK_ENDED
        )
        self.assertEqual(audit_event.actor, self.actor)
        self.assertEqual(audit_event.subject_user, self.subject)
        self.assertEqual(audit_event.subject_email, self.subject.email)
        self.assertEqual(audit_event.ip_address, "203.0.113.20")
        self.assertEqual(audit_event.metadata["origin"], "django_hijack")

    def test_user_logged_in_signal_creates_audit_event_and_sends_email(self):
        request = self.request_factory.post(
            "/accounts/login/",
            REMOTE_ADDR="203.0.113.40",
            HTTP_USER_AGENT="login-agent",
        )

        user_logged_in.send(sender=None, request=request, user=self.subject)

        audit_event = core_models.AuditEvent.objects.get(
            event_type=core_models.AuditEventType.USERS_LOGIN_SUCCEEDED
        )
        self.assertEqual(audit_event.actor, self.subject)
        self.assertEqual(audit_event.subject_user, self.subject)
        self.assertEqual(audit_event.ip_address, "203.0.113.40")
        self.assertEqual(audit_event.metadata["origin"], "allauth_account")
        self.assertEqual(len(mail.outbox), 1)
        self.assertEqual(mail.outbox[0].to, [self.subject.email])
        self.assertIn("New sign-in", mail.outbox[0].subject)

    def test_authenticator_removed_signal_creates_audit_event_and_sends_email(self):
        request = self.request_factory.post(
            "/accounts/mfa/",
            REMOTE_ADDR="203.0.113.41",
            HTTP_USER_AGENT="mfa-agent",
        )
        authenticator = Authenticator.objects.create(
            user=self.subject,
            type=Authenticator.Type.TOTP,
            data={"secret": "totp-secret"},
        )

        authenticator_removed.send(
            sender=None,
            request=request,
            user=self.subject,
            authenticator=authenticator,
        )

        audit_event = core_models.AuditEvent.objects.get(
            event_type=core_models.AuditEventType.USERS_MFA_AUTHENTICATOR_REMOVED
        )
        self.assertEqual(audit_event.metadata["authenticator_type"], Authenticator.Type.TOTP)
        self.assertEqual(len(mail.outbox), 1)
        self.assertIn("MFA method removed", mail.outbox[0].subject)

    def test_recovery_codes_regenerated_signal_creates_audit_event_and_sends_email(self):
        request = self.request_factory.post(
            "/accounts/mfa/recovery-codes/",
            REMOTE_ADDR="203.0.113.42",
            HTTP_USER_AGENT="recovery-agent",
        )
        authenticator = Authenticator.objects.create(
            user=self.subject,
            type=Authenticator.Type.RECOVERY_CODES,
            data={"unused_mask": 0, "codes": ["one", "two"]},
        )

        authenticator_reset.send(
            sender=None,
            request=request,
            user=self.subject,
            authenticator=authenticator,
        )

        audit_event = core_models.AuditEvent.objects.get(
            event_type=core_models.AuditEventType.USERS_MFA_RECOVERY_CODES_REGENERATED
        )
        self.assertEqual(
            audit_event.metadata["authenticator_type"],
            Authenticator.Type.RECOVERY_CODES,
        )
        self.assertEqual(len(mail.outbox), 1)
        self.assertIn("Recovery codes regenerated", mail.outbox[0].subject)

    def test_token_created_audit_event_sends_email(self):
        record_audit_event(
            event_type=core_models.AuditEventType.TOKENS_API_TOKEN_CREATED,
            actor=self.subject,
            team=self.team,
            metadata={"name": "Deploy", "environment": "live"},
        )

        self.assertEqual(len(mail.outbox), 1)
        self.assertEqual(mail.outbox[0].to, [self.subject.email])
        self.assertIn("API token created", mail.outbox[0].subject)
        self.assertIn("Token name: Deploy", mail.outbox[0].body)
        self.assertIn("Team: Acme", mail.outbox[0].body)

    def test_security_event_email_respects_user_preference(self):
        self.subject.set_preference("security_event_emails_enabled", False)

        record_audit_event(
            event_type=core_models.AuditEventType.TOKENS_API_TOKEN_CREATED,
            actor=self.subject,
            team=self.team,
            metadata={"name": "Deploy", "environment": "live"},
        )

        self.assertEqual(len(mail.outbox), 0)

    @override_settings(IS_PRODUCTION=True, TRUSTED_PROXY_IPS=["10.0.0.0/8"])
    def test_get_client_ip_ignores_forwarded_header_from_untrusted_peer(self):
        request = self.request_factory.get(
            "/",
            REMOTE_ADDR="203.0.113.30",
            HTTP_X_FORWARDED_FOR="198.51.100.10, 10.0.0.1",
        )

        self.assertEqual(get_client_ip(request), "203.0.113.30")


class TrustedProxyHeadersMiddlewareTestCase(TestCase):
    def setUp(self):
        self.request_factory = RequestFactory()

    @override_settings(
        IS_PRODUCTION=True,
        TRUSTED_PROXY_IPS=["127.0.0.1"],
        SECURE_SSL_REDIRECT=True,
        SECURE_PROXY_SSL_HEADER=("HTTP_X_FORWARDED_PROTO", "https"),
    )
    def test_spoofed_forwarded_proto_is_ignored_for_untrusted_peer(self):
        middleware = TrustedProxyHeadersMiddleware(
            SecurityMiddleware(lambda request: HttpResponse("ok"))
        )
        request = self.request_factory.get(
            "/",
            REMOTE_ADDR="203.0.113.30",
            HTTP_X_FORWARDED_PROTO="https",
        )

        response = middleware(request)

        self.assertEqual(response.status_code, 301)

    @override_settings(
        IS_PRODUCTION=True,
        TRUSTED_PROXY_IPS=["127.0.0.1"],
        SECURE_SSL_REDIRECT=True,
        SECURE_PROXY_SSL_HEADER=("HTTP_X_FORWARDED_PROTO", "https"),
    )
    def test_forwarded_proto_is_honored_for_trusted_peer(self):
        middleware = TrustedProxyHeadersMiddleware(
            SecurityMiddleware(lambda request: HttpResponse("ok"))
        )
        request = self.request_factory.get(
            "/",
            REMOTE_ADDR="127.0.0.1",
            HTTP_X_FORWARDED_PROTO="https",
        )

        response = middleware(request)

        self.assertEqual(response.status_code, 200)


class RequestPerformanceLoggingMiddlewareTestCase(TestCase):
    def setUp(self):
        self.request_factory = RequestFactory()

    @override_settings(
        OBSERVABILITY_SLOW_REQUEST_THRESHOLD_MS=10_000,
        OBSERVABILITY_SLOW_DB_DURATION_MS=10_000,
    )
    def test_request_performance_middleware_logs_request_metrics(self):
        core_models.NewsletterSignup.objects.create(email="metrics@example.com")

        def get_response(request):
            core_models.NewsletterSignup.objects.count()
            return HttpResponse("ok")

        request = self.request_factory.get("/metrics-test")
        request.resolver_match = SimpleNamespace(view_name="metrics_test")
        middleware = RequestPerformanceLoggingMiddleware(get_response)

        with patch("{{ project_name }}.core.middleware.logger") as mock_logger:
            response = middleware(request)

        self.assertEqual(response.status_code, 200)
        mock_logger.info.assert_called_once()
        event_name = mock_logger.info.call_args.args[0]
        log_fields = mock_logger.info.call_args.kwargs
        self.assertEqual(event_name, "http.request_completed")
        self.assertEqual(log_fields["path"], "/metrics-test")
        self.assertEqual(log_fields["view_name"], "metrics_test")
        self.assertEqual(log_fields["status_code"], 200)
        self.assertGreaterEqual(log_fields["db_query_count"], 1)
        self.assertGreaterEqual(log_fields["db_duration_ms"], 0)
        self.assertFalse(log_fields["is_slow_request"])
        self.assertFalse(log_fields["is_slow_db"])

    @override_settings(
        OBSERVABILITY_SLOW_REQUEST_THRESHOLD_MS=0,
        OBSERVABILITY_SLOW_DB_DURATION_MS=0,
    )
    def test_request_performance_middleware_warns_for_slow_requests(self):
        def get_response(request):
            return HttpResponse("ok")

        request = self.request_factory.get("/metrics-test")
        middleware = RequestPerformanceLoggingMiddleware(get_response)

        with patch("{{ project_name }}.core.middleware.logger") as mock_logger:
            middleware(request)

        mock_logger.warning.assert_called_once()
        self.assertEqual(mock_logger.warning.call_args.args[0], "http.request_completed")
        self.assertTrue(mock_logger.warning.call_args.kwargs["is_slow_request"])
        self.assertTrue(mock_logger.warning.call_args.kwargs["is_slow_db"])


class LanguageSwitchingTestCase(TestCase):
    def test_set_language_redirects_and_sets_language_cookie(self):
        response = self.client.post(
            reverse("set_language"),
            {"language": "de", "next": "/"},
        )

        self.assertRedirects(response, "/")
        self.assertEqual(response.cookies[settings.LANGUAGE_COOKIE_NAME].value, "de")


class LocaleRenderingTestCase(TestCase):
    def test_base_template_uses_active_language_in_html_attributes(self):
        response = self.client.get("/", HTTP_ACCEPT_LANGUAGE="de")
        content = response.content.decode()

        self.assertIn('lang="de"', content)
        self.assertIn('dir="ltr"', content)

    @override_settings(LANGUAGES=[*settings.LANGUAGES, ("ar", "Arabic")])
    def test_base_template_sets_rtl_direction_for_bidi_languages(self):
        response = self.client.get("/", HTTP_ACCEPT_LANGUAGE="ar")
        content = response.content.decode()

        self.assertIn('lang="ar"', content)
        self.assertIn('dir="rtl"', content)

    @override_settings(CHATWOOT_WEBSITE_TOKEN="test-token")
    def test_chatwoot_widget_uses_active_language(self):
        self.client.cookies[OPTIONAL_TRACKING_CONSENT_COOKIE_NAME] = (
            OPTIONAL_TRACKING_CONSENT_ACCEPTED
        )

        response = self.client.get("/", HTTP_ACCEPT_LANGUAGE="de")

        self.assertContains(response, "locale: 'de'")

    def test_base_template_includes_react_island_entrypoint(self):
        response = self.client.get("/", HTTP_ACCEPT_LANGUAGE="de")

        self.assertContains(response, "src/main.tsx")

    @override_settings(
        CHATWOOT_WEBSITE_TOKEN="test-token",
        PLAUSIBLE_DOMAIN="example.com",
        PLAUSIBLE_SCRIPT_HOST="https://plausible.example",
    )
    def test_marketing_base_does_not_include_marketing_scripts_without_consent(self):
        response = self.client.get("/")

        self.assertNotContains(response, "https://plausible.example/js/script.js")
        self.assertNotContains(response, "window.chatwootSettings")
        self.assertContains(response, "Allow optional tools")

    @override_settings(
        CHATWOOT_WEBSITE_TOKEN="test-token",
        PLAUSIBLE_DOMAIN="example.com",
        PLAUSIBLE_SCRIPT_HOST="https://plausible.example",
    )
    def test_marketing_base_includes_marketing_scripts_with_consent(self):
        self.client.cookies[OPTIONAL_TRACKING_CONSENT_COOKIE_NAME] = (
            OPTIONAL_TRACKING_CONSENT_ACCEPTED
        )

        response = self.client.get("/")

        self.assertContains(response, "https://plausible.example/js/script.js")
        self.assertContains(response, "window.chatwootSettings")
        self.assertNotContains(response, "Allow optional tools")

    def test_consent_required_template_tag_hides_content_without_consent(self):
        request = RequestFactory().get("/")
        rendered = Template(
            "{"
            + "% load core %}"
            + "{"
            + "% consent_required %}"
            + "<script src='https://example.com/test.js'></script>"
            + "{"
            + "% endconsent_required %}"
        ).render(Context({"request": request}))

        self.assertNotIn("test.js", rendered)

    def test_react_island_template_tag_serializes_props(self):
        rendered = Template(
            "{" + "% load core %}" + "{" + "% react_island 'PricingCalculator' props %}"
        ).render(Context({"props": {"teamSlug": "acme"}}))

        self.assertIn('data-react-island="PricingCalculator"', rendered)
        self.assertIn('data-react-props="{&quot;teamSlug&quot;: &quot;acme&quot;}"', rendered)

    def test_update_optional_tracking_consent_sets_cookie_and_redirects(self):
        response = self.client.post(
            reverse("consent_update"),
            {"choice": "accept", "next": "/pricing/"},
        )

        self.assertRedirects(response, "/pricing/")
        self.assertEqual(
            response.cookies[OPTIONAL_TRACKING_CONSENT_COOKIE_NAME].value,
            OPTIONAL_TRACKING_CONSENT_ACCEPTED,
        )

    def test_default_debug_config_uses_report_only_csp(self):
        response = self.client.get("/")

        self.assertNotIn("Content-Security-Policy", response.headers)
        self.assertIn("Content-Security-Policy-Report-Only", response.headers)
        self.assertEqual(response.headers["Cross-Origin-Opener-Policy"], "same-origin")
        self.assertEqual(response.headers["Cross-Origin-Resource-Policy"], "same-site")
        self.assertEqual(
            response.headers["Permissions-Policy"],
            "camera=(), microphone=(), geolocation=(), interest-cohort=()",
        )

    @override_settings(
        SECURE_CSP={
            "default-src": [CSP.SELF],
            "script-src": [CSP.SELF, "https://plausible.example"],
        },
        SECURE_CSP_REPORT_ONLY={},
    )
    def test_enforced_csp_header_is_applied_when_configured(self):
        response = self.client.get("/")

        self.assertIn("Content-Security-Policy", response.headers)
        self.assertNotIn("Content-Security-Policy-Report-Only", response.headers)
        self.assertIn("default-src 'self'", response.headers["Content-Security-Policy"])
        self.assertIn(
            "script-src 'self' https://plausible.example",
            response.headers["Content-Security-Policy"],
        )


class InternationalizationTestCase(TestCase):
    def test_newsletter_duplicate_error_is_marked_for_translation(self):
        self.assertIsInstance(NewsletterSignupForm.ALREADY_SUBSCRIBED_ERROR, Promise)

    def test_core_templates_mark_user_facing_copy_for_translation(self):
        template_dir = Path(__file__).resolve().parent / "templates" / "core"
        template_paths = [
            template_dir / "pages" / "coming_soon.html",
            template_dir / "pages" / "dashboard.html",
            template_dir / "pages" / "homepage.html",
            template_dir / "pages" / "newsletter" / "signup.html",
            template_dir / "pages" / "newsletter" / "success.html",
            template_dir / "pages" / "newsletter" / "confirmed.html",
            template_dir / "pages" / "pricing.html",
            template_dir / "partials" / "footer.html",
            template_dir / "partials" / "newsletter" / "signup.html",
        ]

        for template_path in template_paths:
            with self.subTest(template_path=template_path):
                content = template_path.read_text()
                self.assertTrue(
                    "{%" + " trans" in content or "{%" + " blocktrans" in content,
                    f"Expected translation markers in {template_path}",
                )


class TranslateLocaleCommandTestCase(TestCase):
    def test_translate_locale_updates_untranslated_entries(self):
        with tempfile.TemporaryDirectory() as temp_dir:
            base_dir = Path(temp_dir)
            locale_dir = base_dir / "locale" / "de" / "LC_MESSAGES"
            locale_dir.mkdir(parents=True)
            po_file_path = locale_dir / "django.po"

            po_file = polib.POFile()
            po_file.metadata = {
                "Language": "de",
                "Plural-Forms": "nplurals=2; plural=(n != 1);",
            }
            po_file.append(polib.POEntry(msgid="Sign In", msgstr=""))
            po_file.append(
                polib.POEntry(
                    msgid="There is %(count)s team.",
                    msgid_plural="There are %(count)s teams.",
                    msgstr_plural={0: "", 1: ""},
                )
            )
            po_file.save(str(po_file_path))

            with (
                override_settings(BASE_DIR=base_dir),
                patch.dict(os.environ, {"AI_TRANSLATION_API_KEY": "test-key"}),
                patch(
                    "{{ project_name }}.core.management.commands.translate_locale.request_translations",  # noqa: E501
                    return_value=[
                        {"index": 0, "msgstr": "Anmelden"},
                        {
                            "index": 1,
                            "msgstr_plural": [
                                "Es gibt %(count)s Team.",
                                "Es gibt %(count)s Teams.",
                            ],
                        },
                    ],
                ),
            ):
                call_command("translate_locale", locale="de")

            updated_po_file = polib.pofile(str(po_file_path))
            self.assertEqual(updated_po_file.find("Sign In").msgstr, "Anmelden")
            plural_entry = updated_po_file.find("There is %(count)s team.")
            self.assertEqual(plural_entry.msgstr_plural[0], "Es gibt %(count)s Team.")
            self.assertEqual(plural_entry.msgstr_plural[1], "Es gibt %(count)s Teams.")
