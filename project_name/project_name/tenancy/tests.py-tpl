"""Tests for team-first tenancy."""

from datetime import timedelta
from unittest.mock import patch

import pytest
from allauth.account.models import EmailAddress
from allauth.mfa.models import Authenticator
from django.contrib.auth.models import AnonymousUser
from django.contrib.messages import get_messages
from django.db import IntegrityError
from django.http import Http404, HttpResponse
from django.test import RequestFactory
from django.urls import reverse
from django.utils import timezone

from {{ project_name }}.billing import models as billing_models
from {{ project_name }}.core.models import AuditEvent, AuditEventType
from {{ project_name }}.tenancy import context, middleware, models, permissions, services


@pytest.mark.django_db
class TestTeamServices:
    def test_create_team_adds_owner_membership(self, owner):
        team = services.create_team(name="Acme", slug="acme", owner=owner)

        membership = models.TeamMembership.all_objects.get(team=team, user=owner)
        assert membership.role == models.TeamRole.OWNER

        audit_event = AuditEvent.objects.get(event_type=AuditEventType.TENANCY_TEAM_CREATED)
        assert audit_event.actor == owner
        assert audit_event.subject_user == owner
        assert audit_event.team == team
        assert audit_event.metadata["team_slug"] == team.slug

    def test_create_and_accept_invitation(self, owner, outsider, team):
        invitation = services.create_invitation(
            actor=owner,
            team=team,
            email=outsider.email,
            role=models.TeamRole.MEMBER,
        )

        created_event = AuditEvent.objects.get(event_type=AuditEventType.TENANCY_INVITATION_CREATED)
        assert created_event.actor == owner
        assert created_event.subject_email == outsider.email
        assert created_event.team == team
        assert created_event.metadata["invitation_id"] == str(invitation.id)

        membership = services.accept_invitation_from_token(
            token=services.get_invitation_token(invitation=invitation),
            user=outsider,
        )

        invitation.refresh_from_db()
        assert membership.team == team
        assert membership.user == outsider
        assert invitation.accepted_at is not None

        accepted_event = AuditEvent.objects.get(
            event_type=AuditEventType.TENANCY_INVITATION_ACCEPTED
        )
        assert accepted_event.actor == outsider
        assert accepted_event.subject_user == outsider
        assert accepted_event.team == team
        assert accepted_event.metadata["invitation_id"] == str(invitation.id)

    def test_accept_invitation_rejects_wrong_email(self, owner, outsider, team):
        invitation = services.create_invitation(
            actor=owner,
            team=team,
            email="someone-else@example.com",
            role=models.TeamRole.MEMBER,
        )

        with pytest.raises(ValueError, match="different email"):
            services.accept_invitation_from_token(
                token=services.get_invitation_token(invitation=invitation),
                user=outsider,
            )

    def test_accept_invitation_rejects_owner_role(self, owner, outsider, team):
        invitation = models.TeamInvitation.all_objects.create(
            team=team,
            email=outsider.email,
            role=models.TeamRole.OWNER,
            invited_by=owner,
            expires_at=timezone.now() + timedelta(days=1),
        )

        with pytest.raises(ValueError, match="Owner role can only be assigned"):
            services.accept_invitation_from_token(
                token=services.get_invitation_token(invitation=invitation),
                user=outsider,
            )

        assert not models.TeamMembership.all_objects.filter(team=team, user=outsider).exists()

    def test_add_user_to_team_records_audit_event(self, owner, outsider, team):
        membership = services.add_user_to_team(
            actor=owner,
            team=team,
            user=outsider,
            role=models.TeamRole.ADMIN,
        )

        audit_event = AuditEvent.objects.get(event_type=AuditEventType.TENANCY_MEMBERSHIP_ADDED)
        assert audit_event.actor == owner
        assert audit_event.subject_user == outsider
        assert audit_event.team == team
        assert audit_event.metadata["role"] == membership.role

    def test_add_user_to_team_rejects_owner_role(self, owner, outsider, team):
        with pytest.raises(ValueError, match="Owner role can only be assigned"):
            services.add_user_to_team(
                actor=owner,
                team=team,
                user=outsider,
                role=models.TeamRole.OWNER,
            )

        assert not models.TeamMembership.all_objects.filter(team=team, user=outsider).exists()

    def test_transfer_team_ownership(self, owner, member_user, team, member_membership, rf):
        request = rf.post("/")
        request.user = owner
        request.session = {}

        with patch(
            "{{ project_name }}.tenancy.services.did_recently_reauthenticate",
            return_value=True,
        ):
            membership = services.transfer_team_ownership(
                actor=owner,
                team=team,
                new_owner=member_user,
                request=request,
            )

        membership.refresh_from_db()
        owner_membership = models.TeamMembership.all_objects.get(team=team, user=owner)
        assert membership.role == models.TeamRole.OWNER
        assert owner_membership.role == models.TeamRole.ADMIN

        audit_event = AuditEvent.objects.get(
            event_type=AuditEventType.TENANCY_OWNERSHIP_TRANSFERRED
        )
        assert audit_event.actor == owner
        assert audit_event.subject_user == member_user
        assert audit_event.team == team
        assert audit_event.metadata["previous_owner"] == owner.email
        assert audit_event.metadata["new_owner"] == member_user.email

    def test_transfer_team_ownership_rejects_self(self, owner, team, rf):
        request = rf.post("/")
        request.user = owner
        request.session = {}

        with (
            patch(
                "{{ project_name }}.tenancy.services.did_recently_reauthenticate",
                return_value=True,
            ),
            pytest.raises(ValueError, match="different team member"),
        ):
            services.transfer_team_ownership(
                actor=owner,
                team=team,
                new_owner=owner,
                request=request,
            )

    def test_transfer_team_ownership_requires_existing_member(self, owner, outsider, team, rf):
        request = rf.post("/")
        request.user = owner
        request.session = {}

        with (
            patch(
                "{{ project_name }}.tenancy.services.did_recently_reauthenticate",
                return_value=True,
            ),
            pytest.raises(ValueError, match="must already be a member"),
        ):
            services.transfer_team_ownership(
                actor=owner,
                team=team,
                new_owner=outsider,
                request=request,
            )

    def test_transfer_team_ownership_requires_recent_reauthentication(
        self, owner, member_user, team, member_membership, rf
    ):
        request = rf.post("/")
        request.user = owner
        request.session = {}

        with pytest.raises(ValueError, match="Please reauthenticate"):
            services.transfer_team_ownership(
                actor=owner,
                team=team,
                new_owner=member_user,
                request=request,
            )

    def test_validate_team_vat_number_updates_team_and_records_audit_event(self, owner, team):
        with pytest.MonkeyPatch.context() as mp:
            mp.setattr(services, "_check_vies_vat_number", lambda country, number: True)

            updated_team = services.validate_team_vat_number(
                actor=owner,
                team=team,
                billing_country="de",
                vat_number="DE 123 456 789",
            )

        updated_team.refresh_from_db()
        assert updated_team.billing_country == "DE"
        assert updated_team.vat_number == "123456789"
        assert updated_team.vat_validated_at is not None

        audit_event = AuditEvent.objects.get(event_type=AuditEventType.TENANCY_VAT_VALIDATED)
        assert audit_event.actor == owner
        assert audit_event.team == team
        assert audit_event.metadata["billing_country"] == "DE"
        assert audit_event.metadata["vat_number"] == "123456789"

    def test_validate_team_vat_number_rejects_invalid_vat(self, owner, team):
        with pytest.MonkeyPatch.context() as mp:
            mp.setattr(services, "_check_vies_vat_number", lambda country, number: False)

            with pytest.raises(ValueError, match="not valid"):
                services.validate_team_vat_number(
                    actor=owner,
                    team=team,
                    billing_country="DE",
                    vat_number="123456789",
                )

        team.refresh_from_db()
        assert team.billing_country in {None, ""}
        assert team.vat_number in {None, ""}
        assert team.vat_validated_at is None

    def test_non_owner_cannot_validate_team_vat_number(self, admin_user, team):
        models.TeamMembership.all_objects.create(
            team=team,
            user=admin_user,
            role=models.TeamRole.ADMIN,
        )

        with pytest.raises(ValueError, match="permission"):
            services.validate_team_vat_number(
                actor=admin_user,
                team=team,
                billing_country="DE",
                vat_number="123456789",
            )

    def test_send_invitation_email(self, owner, team, rf, mailoutbox):
        invitation = services.create_invitation(
            actor=owner,
            team=team,
            email="invitee@example.com",
            role=models.TeamRole.ADMIN,
        )
        request = rf.get("/")

        services.send_invitation_email(invitation=invitation, request=request)

        assert len(mailoutbox) == 1
        assert "Acme" in mailoutbox[0].subject
        assert len(mailoutbox[0].alternatives) == 1
        assert mailoutbox[0].alternatives[0].mimetype == "text/html"
        assert "Accept your invitation here:" in mailoutbox[0].body

    def test_create_invitation_rejects_owner_role(self, owner, team):
        with pytest.raises(ValueError, match="Owner role can only be assigned"):
            services.create_invitation(
                actor=owner,
                team=team,
                email="invitee@example.com",
                role=models.TeamRole.OWNER,
            )

        assert not models.TeamInvitation.all_objects.filter(
            team=team,
            email="invitee@example.com",
        ).exists()

    def test_team_cannot_have_two_owner_memberships(self, team, outsider):
        with pytest.raises(IntegrityError):
            models.TeamMembership.all_objects.create(
                team=team,
                user=outsider,
                role=models.TeamRole.OWNER,
            )

    def test_different_teams_can_have_different_owners(self, outsider):
        another_team = models.Team.objects.create(name="Gamma", slug="gamma")

        membership = models.TeamMembership.all_objects.create(
            team=another_team,
            user=outsider,
            role=models.TeamRole.OWNER,
        )

        assert membership.role == models.TeamRole.OWNER


@pytest.mark.django_db
class TestPermissions:
    def test_role_permission_matrix(
        self, owner, admin_user, member_user, team, admin_membership, member_membership
    ):

        assert (
            permissions.user_has_team_perm(
                user=owner,
                permission_name="tenancy.manage_team_billing",
                team=team,
            )
            is True
        )
        assert (
            permissions.user_has_team_perm(
                user=admin_user,
                permission_name="tenancy.manage_team_billing",
                team=team,
            )
            is False
        )
        assert (
            permissions.user_has_team_perm(
                user=admin_user,
                permission_name="billing.change_subscription",
                team=team,
            )
            is True
        )
        assert (
            permissions.user_has_team_perm(
                user=member_user,
                permission_name="billing.change_subscription",
                team=team,
            )
            is False
        )
        assert (
            permissions.user_has_team_perm(
                user=member_user,
                permission_name="billing.view_subscription",
                team=team,
            )
            is True
        )


@pytest.mark.django_db
class TestMiddleware:
    def test_active_team_middleware_sets_request_team(self, owner, team):
        captured = {}
        request = RequestFactory().get(f"/t/{team.slug}/dashboard")
        request.user = owner

        def get_response(req):
            captured["team"] = req.team
            captured["membership"] = req.team_membership
            return HttpResponse("ok")

        response = middleware.ActiveTeamMiddleware(get_response)(request)

        assert response.status_code == 200
        assert captured["team"] == team
        assert captured["membership"].user == owner

    def test_active_team_middleware_rejects_non_member(self, outsider, team):
        request = RequestFactory().get(f"/t/{team.slug}/dashboard")
        request.user = outsider

        def get_response(req):
            return HttpResponse("ok")

        with pytest.raises(Http404):
            middleware.ActiveTeamMiddleware(get_response)(request)

    def test_active_team_middleware_allows_anonymous_resolution(self, team):
        captured = {}
        request = RequestFactory().get(f"/t/{team.slug}/dashboard")
        request.user = AnonymousUser()

        def get_response(req):
            captured["team"] = req.team
            return HttpResponse("ok")

        response = middleware.ActiveTeamMiddleware(get_response)(request)

        assert response.status_code == 200
        assert captured["team"] == team


@pytest.mark.django_db
class TestViews:
    def test_transfer_team_ownership_view_redirects_after_success(
        self, client, owner, member_user, team, member_membership
    ):
        EmailAddress.objects.create(
            user=owner,
            email=owner.email,
            primary=True,
            verified=True,
        )
        Authenticator.objects.create(
            user=owner,
            type=Authenticator.Type.TOTP,
            data={"secret": "totp-secret"},
        )
        client.force_login(owner)

        with patch(
            "{{ project_name }}.tenancy.services.did_recently_reauthenticate",
            return_value=True,
        ):
            response = client.post(
                reverse("transfer_team_ownership", kwargs={"team_slug": team.slug}),
                data={"user_id": member_user.pk},
            )

        assert response.status_code == 302
        assert response.headers["Location"] == reverse(
            "team_settings",
            kwargs={"team_slug": team.slug},
        )

        owner_membership = models.TeamMembership.all_objects.get(team=team, user=owner)
        member_membership.refresh_from_db()
        assert owner_membership.role == models.TeamRole.ADMIN
        assert member_membership.role == models.TeamRole.OWNER

        messages = [message.message for message in get_messages(response.wsgi_request)]
        assert f"{member_user.email} is now the owner of {team.name}." in messages

    def test_transfer_team_ownership_view_rejects_missing_user(
        self, client, owner, member_user, team, member_membership
    ):
        EmailAddress.objects.create(
            user=owner,
            email=owner.email,
            primary=True,
            verified=True,
        )
        Authenticator.objects.create(
            user=owner,
            type=Authenticator.Type.TOTP,
            data={"secret": "totp-secret"},
        )
        client.force_login(owner)

        response = client.post(
            reverse("transfer_team_ownership", kwargs={"team_slug": team.slug}),
            data={"user_id": 999999},
        )

        assert response.status_code == 302
        assert response.headers["Location"] == reverse(
            "team_settings",
            kwargs={"team_slug": team.slug},
        )

        owner_membership = models.TeamMembership.all_objects.get(team=team, user=owner)
        member_membership.refresh_from_db()
        assert owner_membership.role == models.TeamRole.OWNER
        assert member_membership.role == models.TeamRole.MEMBER

        messages = [message.message for message in get_messages(response.wsgi_request)]
        assert "Selected team member not found." in messages

    def test_transfer_team_ownership_view_rejects_missing_user_id(
        self, client, owner, member_user, team, member_membership
    ):
        EmailAddress.objects.create(
            user=owner,
            email=owner.email,
            primary=True,
            verified=True,
        )
        Authenticator.objects.create(
            user=owner,
            type=Authenticator.Type.TOTP,
            data={"secret": "totp-secret"},
        )
        client.force_login(owner)

        response = client.post(
            reverse("transfer_team_ownership", kwargs={"team_slug": team.slug}),
            data={},
        )

        assert response.status_code == 302
        assert response.headers["Location"] == reverse(
            "team_settings",
            kwargs={"team_slug": team.slug},
        )

        owner_membership = models.TeamMembership.all_objects.get(team=team, user=owner)
        member_membership.refresh_from_db()
        assert owner_membership.role == models.TeamRole.OWNER
        assert member_membership.role == models.TeamRole.MEMBER

        messages = [message.message for message in get_messages(response.wsgi_request)]
        assert "Selected team member not found." in messages

    def test_transfer_team_ownership_view_rejects_invalid_user_id(
        self, client, owner, member_user, team, member_membership
    ):
        EmailAddress.objects.create(
            user=owner,
            email=owner.email,
            primary=True,
            verified=True,
        )
        Authenticator.objects.create(
            user=owner,
            type=Authenticator.Type.TOTP,
            data={"secret": "totp-secret"},
        )
        client.force_login(owner)

        response = client.post(
            reverse("transfer_team_ownership", kwargs={"team_slug": team.slug}),
            data={"user_id": "abc123"},
        )

        assert response.status_code == 302
        assert response.headers["Location"] == reverse(
            "team_settings",
            kwargs={"team_slug": team.slug},
        )

        owner_membership = models.TeamMembership.all_objects.get(team=team, user=owner)
        member_membership.refresh_from_db()
        assert owner_membership.role == models.TeamRole.OWNER
        assert member_membership.role == models.TeamRole.MEMBER

        messages = [message.message for message in get_messages(response.wsgi_request)]
        assert "Selected team member not found." in messages


@pytest.mark.django_db
class TestTenantScopedManager:
    def test_scoped_manager_filters_by_active_team_context(self, team, another_team):
        now = timezone.now() + timedelta(days=30)
        billing_models.Subscription.all_objects.create(
            team=team,
            provider=billing_models.BillingProviderChoices.POLAR,
            external_subscription_id="sub_team_a",
            external_customer_id="cust_team_a",
            external_product_id="prod_team_a",
            status=billing_models.SubscriptionStatus.ACTIVE,
            current_period_end=now,
        )
        billing_models.Subscription.all_objects.create(
            team=another_team,
            provider=billing_models.BillingProviderChoices.POLAR,
            external_subscription_id="sub_team_b",
            external_customer_id="cust_team_b",
            external_product_id="prod_team_b",
            status=billing_models.SubscriptionStatus.ACTIVE,
            current_period_end=now,
        )

        with context.team_context(team.id):
            assert list(
                billing_models.Subscription.objects.values_list(
                    "external_subscription_id", flat=True
                )
            ) == ["sub_team_a"]

        assert billing_models.Subscription.all_objects.count() == 2
