"""Tests for team-scoped API tokens."""

from datetime import timedelta

import pytest
from django.contrib.auth import get_user_model
from django.utils import timezone

from {{ project_name }}.tenancy import models as tenancy_models
from {{ project_name }}.tenancy import services as tenancy_services

from . import auth, models, services

User = get_user_model()


@pytest.fixture
def owner(db):
    return User.objects.create_user(email="owner@example.com", password="testpass123")


@pytest.fixture
def admin_user(db):
    return User.objects.create_user(email="admin@example.com", password="testpass123")


@pytest.fixture
def outsider(db):
    return User.objects.create_user(email="outsider@example.com", password="testpass123")


@pytest.fixture
def team(owner):
    return tenancy_services.create_team(name="Acme", slug="acme", owner=owner)


@pytest.fixture
def admin_membership(team, admin_user):
    return tenancy_models.TeamMembership.all_objects.create(
        team=team,
        user=admin_user,
        role=tenancy_models.TeamRole.ADMIN,
    )


@pytest.mark.django_db
class TestTokenServices:
    def test_create_token_returns_plaintext_once(self, team, owner):
        result = services.create_api_token(team=team, user=owner, name="CI")

        assert result.token.name == "CI"
        assert result.plaintext.startswith(f"{models.TOKEN_PREFIX}_{models.TOKEN_ENV_LIVE}_")
        assert result.token.secret_hash != result.plaintext

    def test_revoke_token(self, team, owner):
        result = services.create_api_token(team=team, user=owner, name="CI")
        services.revoke_api_token(token=result.token, user=owner)

        result.token.refresh_from_db()
        assert result.token.revoked_at is not None

    def test_non_admin_cannot_create_token(self, team, outsider):
        with pytest.raises(ValueError, match="permission"):
            services.create_api_token(team=team, user=outsider, name="CI")


@pytest.mark.django_db
class TestTokenAuth:
    def test_parse_token(self):
        parsed = auth.parse_token("mst_live_ABCDEFGHIJKLMNO1abcdefghijklmnopqrstuvwxyz_012345")

        assert parsed is not None
        assert parsed.lookup_id == "ABCDEFGHIJKLMNO1"
        assert parsed.environment == "live"

    def test_bearer_auth_sets_request_team(self, rf, team, owner):
        result = services.create_api_token(team=team, user=owner, name="CI")
        request = rf.get("/api/v1/tokens/me/", HTTP_AUTHORIZATION=f"Bearer {result.plaintext}")

        authenticated = auth.ApiTokenAuth()(request)

        assert authenticated is not None
        assert request.team == team
        assert request.auth_token == authenticated


@pytest.mark.django_db
class TestTokenApi:
    def test_owner_can_list_and_create_tokens(self, client, team, owner):
        client.force_login(owner)

        create_response = client.post(
            f"/api/v1/teams/{team.slug}/tokens/",
            data={"name": "Deploy", "scopes": ["read:projects"]},
            content_type="application/json",
        )
        assert create_response.status_code == 201
        payload = create_response.json()
        assert payload["name"] == "Deploy"
        assert payload["plaintext"].startswith(f"{models.TOKEN_PREFIX}_{models.TOKEN_ENV_LIVE}_")

        list_response = client.get(f"/api/v1/teams/{team.slug}/tokens/")
        assert list_response.status_code == 200
        assert len(list_response.json()) == 1

    def test_admin_can_revoke_token(self, client, team, owner, admin_user, admin_membership):
        result = services.create_api_token(team=team, user=owner, name="Deploy")
        client.force_login(admin_user)

        response = client.delete(f"/api/v1/teams/{team.slug}/tokens/{result.token.token_id}/")

        assert response.status_code == 204
        result.token.refresh_from_db()
        assert result.token.revoked_at is not None

    def test_bearer_token_can_call_me_endpoint(self, client, team, owner):
        result = services.create_api_token(
            team=team,
            user=owner,
            name="Deploy",
            expires_at=timezone.now() + timedelta(days=1),
        )

        response = client.get(
            "/api/v1/tokens/me/",
            HTTP_AUTHORIZATION=f"Bearer {result.plaintext}",
        )

        assert response.status_code == 200
        payload = response.json()
        assert payload["token_id"] == result.token.token_id
        assert payload["team_slug"] == team.slug

    def test_revoked_token_cannot_authenticate(self, client, team, owner):
        result = services.create_api_token(team=team, user=owner, name="Deploy")
        services.revoke_api_token(token=result.token, user=owner)

        response = client.get(
            "/api/v1/tokens/me/",
            HTTP_AUTHORIZATION=f"Bearer {result.plaintext}",
        )

        assert response.status_code == 401
